## Count primes up to N using sieve of Eratosthenes (i64 flags, 0=composite 1=prime)
fn count_primes(limit: i64) -> i64 {
    let mut sieve: vec<i64> = vec_new()
    let mut i: i64 = 0
    loop {
        if i > limit { break }
        vec_push(sieve, 1)
        i = i + 1
    }
    i = 2
    loop {
        if i * i > limit { break }
        if sieve[i as u64] == 1 {
            let mut j = i * i
            loop {
                if j > limit { break }
                sieve[j as u64] = 0
                j = j + i
            }
        }
        i = i + 1
    }
    let mut count: i64 = 0
    i = 2
    loop {
        if i > limit { break }
        if sieve[i as u64] == 1 { count = count + 1 }
        i = i + 1
    }
    count
}

fn main() -> unit {
    print(_cnd_int_to_str(count_primes(1000000)))
}
